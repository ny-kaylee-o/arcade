<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="540" prefWidth="960" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ch.noseryoung.arcade.HelloController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <!-- Placeholder background: replace with an ImageView once you have your own art -->
    <Rectangle height="540" styleClass="bg-placeholder" width="960" />

    <VBox alignment="CENTER" spacing="60">
        <Text fill="WHITE" styleClass="title-text" text=":3">
         <font>
            <Font size="96.0" />
         </font></Text>

        <VBox alignment="CENTER" spacing="20">
            <Button onAction="#onPlayClicked" styleClass="arcade-button" text="PLAY" />
            <Button onAction="#onExitClicked" styleClass="arcade-button" text="EXIT" />
        </VBox>
    </VBox>

</StackPane>
